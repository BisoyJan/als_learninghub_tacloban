# ALS Connect Tacloban — Production Environment Configuration
# Copy this file to .env on your production server and fill in the values.

APP_NAME="ALS Connect Tacloban"
APP_ENV=production
APP_KEY=                          # Generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://alsconnect.ph     # Your production domain

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — use daily rotation in production
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — MySQL for production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alsconnect
DB_USERNAME=alsconnect_user
DB_PASSWORD=                      # Set a strong password

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=alsconnect.ph      # Your domain
SESSION_SECURE_COOKIE=true

# Broadcasting / Filesystem / Queue / Cache
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public            # For file uploads
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail — configure your SMTP provider
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com        # Your SMTP host
MAIL_PORT=587
MAIL_USERNAME=                    # Your SMTP username
MAIL_PASSWORD=                    # Your SMTP password
MAIL_FROM_ADDRESS=noreply@alsconnect.ph
MAIL_FROM_NAME="ALS Connect Tacloban"

VITE_APP_NAME="${APP_NAME}"
